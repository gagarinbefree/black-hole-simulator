{
  "name": "black-hole-simulator",
  "version": "1.0.0",
  "type": "module",
  "description": "Relativistic black hole simulation with plasma accretion disk",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --testLocationInResults",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,js --fix",
    "format": "prettier --write .",
    "clean": "rm -rf dist coverage .nyc_output",
    "prebuild": "npm run type-check && npm run test:ci",
    "build:ci": "npm ci && npm run build",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "three": "^0.128.0"
  },
  "devDependencies": {
    "@types/three": "^0.128.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "gh-pages": "^6.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}